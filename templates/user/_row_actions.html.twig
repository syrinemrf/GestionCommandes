<div class="table-actions">

    <a
        href="{{ path('user_edit', {'id': user.id}) }}"
        class="table-action">

        Modifier

    </a>

    <form
        method="POST"
        action="{{ path('user_delete', {'id': user.id}) }}"
        class="delete-form"
        data-user-id="{{ user.id }}">

        <input
            type="hidden"
            name="_token"
            value="{{ csrf_token('delete-user-' ~ user.id) }}">

        <button
            type="submit"
            class="table-action table-action-danger">

            Supprimer

        </button>

    </form>

</div>