{% extends 'base.html.twig' %}


{% block title %}
Modifier un utilisateur
{% endblock %}


{% block body %}

<div class="form-card">

    <div class="form-header">

        <h1>Modifier un utilisateur</h1>

        <a href="{{ path('user_list') }}" class="btn-secondary">
            Retour
        </a>

    </div>


    <form id="user-form" method="POST" action="{{ path('user_edit', { id: user.id }) }}" data-success-message="Utilisateur modifié avec succès." data-reset-form="false">

        <input type="hidden" name="_token" value="{{ csrf_token('user-edit-' ~ user.id) }}">

        <div class="form-row">

            <div class="form-group">

                <label for="nom">
                    Nom
                </label>

                <input 
                    type="text"
                    id="nom"
                    name="nom"
                    placeholder="Nom"
                    value="{{ user.nom }}"
                    required>

            </div>



            <div class="form-group">

                <label for="prenom">
                    Prénom
                </label>

                <input 
                    type="text"
                    id="prenom"
                    name="prenom"
                    placeholder="Prénom"
                    value="{{ user.prenom }}"
                    required>

            </div>

        </div>


        <div class="form-row">

            <div class="form-group">

                <label for="email">
                    Email
                </label>

                <input 
                    type="email"
                    id="email"
                    name="email"
                    placeholder="Email"
                    value="{{ user.email }}"
                    data-check-url="{{ path('user_check_email') }}"
                    data-user-id="{{ user.id }}"
                    readonly
                    required>

            </div>


            <div class="form-group">

                <label for="password">
                    Mot de passe
                </label>

                <input 
                    type="password"
                    id="password"
                    name="password"
                    placeholder="Laisser vide pour ne pas modifier">

            </div>

        </div>

        <div class="form-group">

            <label>
                Rôle
            </label>
            

            <div class="roles">


                <label>
                    <input 
                        type="radio"
                        name="role"
                        value="ROLE_ADMIN"
                        class="role-choice"
                        {% if user.role == 'ROLE_ADMIN' %}checked{% endif %}>

                    Administrateur
                </label>



                <label>
                    <input 
                        type="radio"
                        name="role"
                        value="ROLE_FOURNISSEUR"
                        class="role-choice"
                        {% if user.role == 'ROLE_FOURNISSEUR' %}checked{% endif %}>

                    Fournisseur
                </label>


            </div>

            <div 
                id="libelle-container"
                class="form-group"
                style="display:none">


                <label for="libelle">
                    Libellé fournisseur
                </label>


                <input
                    type="text"
                    id="libelle"
                    name="libelle"
                    placeholder="Nom du fournisseur"
                    value="{{ user.libelle }}">


            </div>

        </div>





        <button type="submit" class="btn-primary">

            Modifier

        </button>


    </form>


</div>

{% endblock %}


{% block javascripts %}
    {{ parent() }}

    <script src="{{ asset('vendor/jquery/jquery-3.7.1.min.js') }}"></script>
    <script src="{{ asset('js/app.js') }}"></script>
    <script src="{{ asset('js/user.js') }}"></script>
{% endblock %}
