{% extends "base.html.twig" %}

{% block title %}Connexion - Gestion Commandes{% endblock %}

{% block body %}

<div class="form-card">

    <h1>Connexion</h1>

    <p class="login-text">
        Connectez-vous à votre compte.
    </p>

    {% if error %}
        <div class="login-error">
            <i class="bi bi-exclamation-circle"></i>
            Le nom d'utilisateur ou le mot de passe est incorrect.
        </div>
    {% endif %}

    <form
        method="POST"
        action="{{ path('app_login') }}"
    >

        <div class="form-group">

            <label for="username">
                Email
            </label>

            <input
                type="email"
                id="username"
                name="_username"
                value="{{ last_username }}"
                placeholder="Email"
                required
                autofocus
            >

        </div>

        <div class="form-group">

            <label for="password">
                Mot de passe
            </label>

            <input
                type="password"
                id="password"
                name="_password"
                placeholder="Mot de passe"
                required
            >

        </div>

        <button
            type="submit"
            class="btn-primary"
        >

            <i class="bi bi-box-arrow-in-right"></i>

            Connexion

        </button>

    </form>

</div>

{% endblock %}