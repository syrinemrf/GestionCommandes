{% extends 'base.html.twig' %}

{% block title %}
Modifier un produit
{% endblock %}

{% block body %}

<div class="form-card">

    <div class="form-header">

        <h1>Modifier un produit</h1>

        <a href="{{ path('product_list') }}" class="btn-secondary">
            Retour
        </a>

    </div>

    <form id="product-form" method="POST" action="{{ path('product_edit', { id: product.id }) }}" data-success-message="Produit modifié avec succès." data-reset-form="false" enctype="multipart/form-data">

        <input type="hidden" name="_token" value="{{ csrf_token('product-edit-' ~ product.id) }}">

        <div class="form-group">

            <label for="libelle">
                Libellé
            </label>

            <input
                type="text"
                id="libelle"
                name="libelle"
                placeholder="Libellé du produit"
                value="{{ product.libelle }}"
                required>

        </div>

        <div class="form-group">

            <label for="description">
                Description
            </label>

            <textarea
                id="description"
                name="description"
                rows="4"
                placeholder="Description du produit"
                required>{{ product.description }}</textarea>

        </div>

        <div class="form-row">
            <div class="form-group">

                <label for="prix">
                    Prix
                </label>

                <input
                    type="text"
                    id="prix"
                    name="prix"
                    placeholder="0.00"
                    value="{{ product.prix }}"
                    required>

            </div>
        </div>

        <div class="form-group product-image-field">
            <label>Image du produit</label>

            <div class="image-uploader" id="image-uploader">
                <input
                    type="file"
                    id="image"
                    name="image"
                    accept="image/jpeg,image/png,image/webp"
                    class="image-input">

                <input type="hidden" id="remove-image-value" name="remove_image" value="0">

                <label for="image" class="image-upload-zone" {% if product.image %}hidden{% endif %}>
                    <i class="bi bi-cloud-arrow-up"></i>
                    <span class="image-upload-title">Choisir une image</span>
                    <small>JPEG, PNG ou WebP — maximum 5 Mo</small>
                </label>

                <div
                    class="image-preview-container"
                    id="image-preview-container"
                    {% if not product.image %}hidden{% endif %}>
                    <img
                        id="image-preview"
                        class="image-preview"
                        src="{{ product.image ? asset(product_images_public_path ~ '/' ~ product.image) : '' }}"
                        alt="Aperçu du produit">

                    <button
                        type="button"
                        id="remove-image"
                        class="remove-image-button"
                        aria-label="Enlever l’image">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>
        </div>

        {% if is_granted('ROLE_ADMIN') %}
            <div class="form-group">

                <label for="fournisseur">
                    Fournisseur
                </label>

                <select id="fournisseur" name="fournisseur">
                    {% for fournisseur in fournisseurs %}
                        <option value="{{ fournisseur.id }}"
                            {% if product.fournisseur and product.fournisseur.id == fournisseur.id %}selected{% endif %}>
                            {{ fournisseur.nom }} {{ fournisseur.prenom }}
                            {% if fournisseur.libelle %}
                                ({{ fournisseur.libelle }})
                            {% endif %}
                        </option>
                    {% endfor %}
                </select>

            </div>
        {% endif %}

        <button type="submit" class="btn-primary">
            Modifier
        </button>

    </form>

</div>

<div class="form-card product-variations-card">

            <div class="form-header">
                <div>
                    <h2>Variations</h2>
                    <p>
                        Stock total :
                        <strong id="product-stock-total">{{ stockTotal }}</strong>
                    </p>
                </div>

                <button
                    type="button"
                    class="btn-primary"
                    id="add-variation-button">
                    Ajouter une variation
                </button>
            </div>

            <div class="table-wrapper">
                <table
                    id="variations-table"
                    class="user-table variation-table"
                    data-url="{{ path('product_variation_list', {productId: product.id}) }}">
                    <thead>
                        <tr>
                            <th>Libellé</th>
                            <th>Caractéristiques</th>
                            <th>Référence</th>
                            <th>Supplément</th>
                            <th>Prix final</th>
                            <th>Stock</th>
                            <th></th>
                        </tr>
                    </thead>
                </table>
            </div>

    </div>

<div id="variation-modal" class="variation-modal" role="dialog" aria-modal="true" aria-labelledby="variation-form-title" hidden>
    <div class="variation-modal-dialog">
        <button type="button" class="variation-modal-close" id="close-variation-modal" aria-label="Fermer">
            <i class="bi bi-x-lg"></i>
        </button>

        <form
            id="variation-form"
            method="post"
            action="{{ path('product_variation_add', {productId: product.id}) }}"
            data-add-url="{{ path('product_variation_add', {productId: product.id}) }}"
            data-add-token="{{ csrf_token('product-variation-add-' ~ product.id) }}">
        <input type="hidden" id="variation-token" name="_token" value="{{ csrf_token('product-variation-add-' ~ product.id) }}">

        <div class="variation-form-header">
            <h3 id="variation-form-title">Nouvelle variation</h3>
            <p>Renseignez une ligne de stock et ses caractéristiques.</p>
        </div>

        <div class="form-group">
            <label for="variation-libelle">Libellé</label>
            <input type="text" id="variation-libelle" name="libelle" placeholder="Exemple : Rouge - Taille M" maxlength="255" required>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="variation-reference">Référence</label>
                <input type="text" id="variation-reference" name="reference" placeholder="Exemple : TSH-ROU-M" maxlength="100">
            </div>
            <div class="form-group">
                <label for="variation-prix">Supplément de prix</label>
                <input type="text" id="variation-prix" name="prixSupplement" value="0.000" inputmode="decimal" required>
            </div>
            <div class="form-group">
                <label for="variation-stock">Stock</label>
                <input type="number" id="variation-stock" name="stock" value="0" min="0" required>
            </div>
        </div>

        <div class="form-group">
            <div class="attribute-section-header">
                <div>
                    <label>Caractéristiques <small>(facultatif)</small></label>
                    <p class="attribute-help">Laissez vide pour afficher « Standard ».</p>
                </div>
                <button type="button" class="btn-secondary" id="add-attribute-button">
                    Ajouter une caractéristique
                </button>
            </div>

            <div id="attribute-list"></div>
        </div>

        <div class="form-actions">
            <button type="button" class="btn-secondary" id="cancel-variation">Annuler</button>
            <button type="submit" class="btn-primary">Enregistrer la variation</button>
        </div>
        </form>
    </div>
</div>

<template id="attribute-row-template">
    <div class="attribute-row">
        <input type="text" name="attribut_nom[]" placeholder="Exemple : Couleur" aria-label="Nom de la caractéristique">
        <input type="text" name="attribut_valeur[]" placeholder="Exemple : Rouge" aria-label="Valeur de la caractéristique">
        <button type="button" class="remove-attribute-button" aria-label="Supprimer cette caractéristique">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>
</template>

{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script src="{{ asset('vendor/jquery/jquery-3.7.1.min.js') }}"></script>
    <script src="{{ asset('vendor/datatables/dataTables.min.js') }}"></script>
    <script src="{{ asset('js/app.js') }}"></script>
    <script src="{{ asset('js/product.js') }}"></script>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('vendor/datatables/dataTables.dataTables.min.css') }}">
{% endblock %}
