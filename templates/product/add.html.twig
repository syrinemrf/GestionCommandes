{% extends 'base.html.twig' %}

{% block title %}
Ajouter un produit
{% endblock %}

{% block body %}

<div class="form-card product-form-card">

    <div class="form-header">

        <h1>Ajouter un produit</h1>

        <a href="{{ path('product_list') }}" class="btn-secondary">
            Retour
        </a>

    </div>

    <form id="product-form" method="POST" action="{{ path('product_add') }}" data-success-message="Produit ajouté avec succès." data-reset-form="true" enctype="multipart/form-data">

        <input type="hidden" name="_token" value="{{ csrf_token('product-add') }}">

        <div class="product-form-layout">
            <div class="product-form-main">

        <div class="form-group">

            <label for="libelle">
                Libellé <span class="required-mark" aria-hidden="true">*</span>
            </label>

            <input
                type="text"
                id="libelle"
                name="libelle"
                placeholder="Libellé du produit"
                required>

        </div>

        <div class="form-group">

            <label for="description">
                Description <span class="required-mark" aria-hidden="true">*</span>
            </label>

            <textarea
                id="description"
                name="description"
                rows="4"
                placeholder="Description du produit"
                required></textarea>

        </div>

        <div class="form-row">
            <div class="form-group">

                <label for="prix">
                    Prix de base <span class="required-mark" aria-hidden="true">*</span>
                </label>

                <div class="input-with-addon">
                    <input type="text" id="prix" name="prix" placeholder="0.000" inputmode="decimal" required>
                    <span class="input-addon">TND</span>
                </div>

            </div>
            </div>

        <fieldset class="form-group product-type-field">
            <legend>
                Type de produit <span class="required-mark" aria-hidden="true">*</span>
            </legend>
            <p class="product-type-help">Sélectionnez le type de produit que vous souhaitez créer.</p>

            <div class="product-type-choice-row">
            <div class="product-type-options">
                <label class="product-type-option">
                    <input type="radio" name="product_type" value="standard" required>
                    <span>Standard</span>
                </label>

                <label class="product-type-option">
                    <input type="radio" name="product_type" value="variations">
                    <span>Avec variations</span>
                </label>
            </div>

            <div class="form-group" id="standard-stock-field" hidden>
                <label for="stock">
                    Stock initial <span class="required-mark" aria-hidden="true">*</span>
                </label>
                <input type="number" id="stock" name="stock" value="0" min="0" required disabled>
            </div>

            <div class="product-variations-next-step" id="variations-next-step" hidden>
                Après avoir cliqué sur « Créer le produit », vous pourrez renseigner ses variations.
            </div>
            </div>
        </fieldset>

        {% if is_granted('ROLE_ADMIN') %}
            <div class="form-group">
                <label for="fournisseur">
                    Fournisseur <span class="required-mark" aria-hidden="true">*</span>
                </label>
                <select id="fournisseur" name="fournisseur" required>
                    {% for fournisseur in fournisseurs %}
                        <option value="{{ fournisseur.id }}">
                            {{ fournisseur.nom }} {{ fournisseur.prenom }}
                            {% if fournisseur.libelle %}({{ fournisseur.libelle }}){% endif %}
                        </option>
                    {% endfor %}
                </select>
            </div>
        {% endif %}

            </div>

            <aside class="product-form-sidebar">

        <div class="form-group product-image-field">
            <label>Image du produit <small>(facultatif)</small></label>

            <div class="image-uploader" id="image-uploader">
                <input
                    type="file"
                    id="image"
                    name="image"
                    accept="image/jpeg,image/png,image/webp"
                    class="image-input">

                <label for="image" class="image-upload-zone">
                    <i class="bi bi-cloud-arrow-up"></i>
                    <span class="image-upload-title">Choisir une image</span>
                    <small>JPEG, PNG ou WebP - maximum 5 Mo</small>
                </label>

                <div class="image-preview-container" id="image-preview-container" hidden>
                    <img id="image-preview" class="image-preview" alt="Aperçu du produit">

                    <button
                        type="button"
                        id="remove-image"
                        class="remove-image-button"
                        aria-label="Enlever l’image">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>
        </div>

            </aside>
        </div>

        <div class="product-form-actions">
            <button type="submit" class="btn-primary async-submit-button">
                <span class="button-label">Créer le produit</span>
                <span class="button-loading"><i class="bi bi-arrow-repeat"></i> Enregistrement...</span>
            </button>
        </div>

    </form>

</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script src="{{ asset('vendor/jquery/jquery-3.7.1.min.js') }}"></script>
    <script src="{{ asset('js/app.js') }}"></script>
    <script src="{{ asset('js/product.js') }}"></script>
{% endblock %}
