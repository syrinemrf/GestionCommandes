<div class="table-actions">

    <a
        href="{{ path('product_edit', {'id': product.id}) }}"
        class="table-action">

        Modifier

    </a>

    <a
        href="{{ path('product_delete', {'id': product.id}) }}"
        class="table-action table-action-danger delete-product"
        data-token="{{ csrf_token('delete-product-' ~ product.id) }}">

            Supprimer

    </a>

</div>
